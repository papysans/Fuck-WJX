{
  "manifest_version": 3,
  "name": "复习面板",
  "version": "0.1.0",
  "description": "本地开卷复习辅助：读取页面题目，结合你的笔记调用你自己配置的 OpenAI 兼容接口生成参考答案。",
  "permissions": ["storage", "activeTab", "scripting", "clipboardWrite"],
  "host_permissions": ["<all_urls>"],
  "background": {
    "service_worker": "src/background.js"
  },
  "content_scripts": [
    {
      "matches": ["https://*.wjx.cn/*", "https://*.wjx.top/*", "https://*.wjx.com/*"],
      "js": ["src/content.js"],
      "run_at": "document_start"
    }
  ],
  "action": {
    "default_popup": "src/popup.html",
    "default_title": "复习面板"
  },
  "commands": {
    "toggle-overlay": {
      "suggested_key": { "default": "Ctrl+Shift+X", "mac": "Command+Shift+X" },
      "description": "显示/隐藏悬浮窗（秒隐）"
    },
    "scan-now": {
      "suggested_key": { "default": "Ctrl+Shift+S", "mac": "Command+Shift+S" },
      "description": "扫题并求答案"
    }
  }
}
